# ─── NVIDIA API Configuration ─────────────────────────────────────────────────
# Get your free API key from: https://build.nvidia.com/
# Click "Get API Key" on any model page
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA NIM LLM Model (for slang normalization, explanations)
# Options: meta/llama-3.1-8b-instruct, mistralai/mistral-7b-instruct-v0.3
NVIDIA_LLM_MODEL=meta/llama-3.1-8b-instruct

# ─── NVIDIA Riva (Optional - Self-hosted) ─────────────────────────────────────
# Only needed if you deploy Riva locally (requires GPU server)
# Leave as-is if using cloud/Edge TTS fallback
RIVA_ASR_URL=grpc://localhost:50051
RIVA_TTS_URL=grpc://localhost:50051

# ─── Fallback Settings ────────────────────────────────────────────────────────
# Set to True to always use open-source models (no NVIDIA API needed)
USE_FALLBACK=False

# Whisper model size for local ASR (tiny/base/small/medium)
# tiny = fastest, least accurate | medium = slowest, most accurate
WHISPER_MODEL=base

# ─── App Settings ─────────────────────────────────────────────────────────────
# Speech speed: 0.7 (very slow) to 1.0 (normal)
DEFAULT_TTS_SPEED=0.85

# ─── Development ──────────────────────────────────────────────────────────────
DEBUG=True
